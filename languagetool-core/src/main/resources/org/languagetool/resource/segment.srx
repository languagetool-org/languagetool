<afterbreak>(und|oder|bis)[\u00A0\s]</afterbreak>
</rule>
<!-- einige deutsche Monate, vor denen eine Zahl erscheinen kann,
         ohne dass eine Satzgrenze erkannt wird
         (z.B. "am 13. Dezember" -> keine Satzgrenze) -->
<rule break="no">
