</rule>
<!-- Break rules -->
<rule break="yes">
<beforebreak>[\.!?\u0085][\u0002|'|"|Â«|\)|\]|\}ÂčÂČÂł]?\s+</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="yes">
