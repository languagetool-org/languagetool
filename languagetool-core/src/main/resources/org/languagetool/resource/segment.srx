<languagerule languagerulename="Ukrainian">
<!-- when sentence starts with ellipsis: ...РңР°Р·С–Р№ С– Р®С…РёРј СӮРөР¶. -->
<rule break="no">
<beforebreak>(^|[\h])(\.\.\.|вҖҰ)</beforebreak>
<afterbreak>\p{Lu}</afterbreak>
</rule>
<!-- РқР°СҲС– РІ... РӣРҫСҒ-РҗРҪРҙР¶РөР»РөСҒС– -->
<rule break="no">
<beforebreak>(?U)\b(РІ|Сғ|РҪР°|Р·Р°|Р·|С–Р·|Р·С–|Р·Рҫ)(\.\.\.|вҖҰ)[\h\v]*</beforebreak>
<afterbreak>\p{Lu}</afterbreak>
</rule>
<rule break="no">
<beforebreak>[.!?вҖҰ][В»вҖң]?[\h]+</beforebreak>
<afterbreak>[\h]*([В«"вҖһвҖң(]|[вҖҗ-вҖ•-][\h])\p{Ll}</afterbreak>
</rule>
<rule break="yes">
<beforebreak>\v[\h]*</beforebreak>
<afterbreak>(\.\.\.|вҖҰ)</afterbreak>
</rule>
<!-- Digit as a point number: 1. РҝРөСҖСҲРёР№ РҝСғРҪРәСӮ -->
<rule break="no">
<beforebreak>(?U)\b\d{1,3}\.[\h]+</beforebreak>
<afterbreak>\p{Ll}|\p{Lu}{2,}</afterbreak>
</rule>
<!-- various punctuation between lowercase letters -->
<rule break="no">
<beforebreak>(?U)\b\p{Ll}+[.!?][\h\v]*</beforebreak>
<afterbreak>\h*(([\(В«]|[\[вҖҗ-вҖ•-][\h\v]*)?\p{Ll})</afterbreak>
</rule>
<rule break="no">
<beforebreak>([\[\(]*[\]\)]*|\.\.\.|вҖҰ)[\h\v]+</beforebreak>
<afterbreak>[\h\v]*\p{Ll}</afterbreak>
</rule>
<!-- lowercase letter abbreviations together: РҪ.Рө., РәРІ.Рј. -->
<rule break="no">
<beforebreak>(?U)\b\p{L}{1,2}\.</beforebreak>
<afterbreak>\p{L}{1,2}\.</afterbreak>
</rule>
<!-- latin capital char abbreviations A. B. C. -->
<rule break="no">
<beforebreak>(?U)\b[\u00A0\u202F]?[A-Z]\.[\h\v]?</beforebreak>
<afterbreak>[A-Z][a-zA-Z'вҖҷ.-]|[Рҗ-РҜРҶРҮР„Тҗ]\.</afterbreak>
</rule>
<!-- capital char abbreviations Рҗ. Р‘. Р’. -->
<rule break="no">
<beforebreak>(?U)(^[\h\v]*|\([\h\v]*|[В«вҖһ"]|(\b[Рҗ-РҜРҶРҮР„ТҗACEIHOPX]\.-))[Рҗ-РҜРҶРҮР„ТҗA-Z]\.[\h\v]*</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- РҶРІР°РҪ Р§. (1914 СҖ. РҪ.) -->
<rule break="no">
<beforebreak>[\h\v][Рҗ-РҜРҶРҮР„Тҗ]\.[\h\v]*</beforebreak>
<afterbreak>[Рҗ-РҜРҶРҮР„Тҗ]\.|[0-9]|[\h\v]*,|[\h\v]*[:В«]|\([0-9]{4}</afterbreak>
</rule>
<!-- РҶ. РҡРҫРІР°Р»СҢ -->
<rule break="no">
<beforebreak>[\h\v.]([Рҗ-РҜРҶРҮР„ТҗACEIHOPX]\.-)?(?&lt;!В°)[Рҗ-РҜРҶРҮР„ТҗABCEIHOPX](?&lt;!(РҡСғР°РҪ[\h]+Р®|(РҹРөСӮСҖ|РһР»РөРәСҒР°РҪРҙСҖ)([Р°РҫСғ]|РҫРІС–|РҫРј)?[\h]+[IРҶ]+))\.[\h\v]*</beforebreak>
<afterbreak>[Рҗ-РҜРҶРҮР„Тҗ][Р°-СҸС–С—С”Т‘Рҗ-РҜРҶРҮР„Тҗ'вҖҷКј]{3}</afterbreak>
</rule>
<!-- РҶРІ. РӨСҖР°РҪРәРҫ (Р°Р»Рө РҶРІ Р‘СғСӮС–Р»СҢС”) -->
<rule break="no">
<beforebreak>(^|[\h\v])(РҶРІ|Р”Р¶|РһР»)\.[\h\v]+</beforebreak>
<afterbreak>[Рҗ-РҜРҶРҮР„ТҗA-Z]</afterbreak>
</rule>
<!-- Year: 2000 СҖ.:
    РІРёСҖРҫРұРёР»Р° Сғ 2018 СҖ. 8,1 РјР»РҪ РҙРөРәР°Р»С–СӮСҖС–РІ
    РІС–Рҙ 26 РәРІС–СӮРҪСҸ 2017 СҖ. в„–35
    Р° РҙРҫ Р»СҺСӮРҫРіРҫ 2020 СҖ. вҖ” Р·Р°СӮРІРөСҖРҙРёСӮРё
-->
<rule break="no">
<beforebreak>(?U)\b([0-9]{2}|[0-9]{4})[\h\v]+СҖ\.[\h\v]+</beforebreak>
<afterbreak>[\h\v]*[в„–0-9вҖҗ-вҖ•-]</afterbreak>
</rule>
<!-- СҖС–СҮРәР° - СҖ. Р”РҪС–РҝСҖРҫ -->
<rule break="no">
<beforebreak>(?U)(?&lt;!\d[\h]*)\bСҖ\.[\h\v]*</beforebreak>
<afterbreak>[\h]*(?!(РқР°|РҗР»Рө|РўР°Рә?)[\h\v]+)[Рҗ-РҜРҶРҮР„ТҗA-Z][^\h]</afterbreak>
</rule>
<!-- РЈ СӮСҖР°РІРҪС– 1949 СҖ. Р“СҖСғСҲРәС–РІСҒСҢРәРёР№ СҖР°Р№РҫРҪ -->
<rule break="no">
<beforebreak>[Рҗ-РҜРҶРҮР„Тҗ][Р°-СҸС–С—С”Т‘'вҖҷ-]*([\h]+[Р°-СҸС–С—С”Т‘'вҖҷ-]+)?[\h](\d{4}[вҖҗ-вҖ•-])*\d{4}[\h]*СҖ\.[\h\v]*</beforebreak>
<afterbreak>[\v\h]*(?!(РқР°|РҗР»Рө|РўР°Рә?)[\h\v]+)[Рҗ-РҜРҶРҮР„ТҗA-Z][^\h\v]</afterbreak>
</rule>
<!-- 15 РІРөСҖРөСҒРҪСҸ 1995 СҖ. РЈРәСҖР°С—РҪРҫСҺ РұСғР»Рҫ РҝС–РҙРҝРёСҒРҪРҫ -->
<rule break="no">
<beforebreak>\d{1,2}[\h]+[Р°-СҸС–С—С”Т‘]+[\h]\d{4}[\h]*СҖ\.[\h\v]*</beforebreak>
<afterbreak>[\h]*(?!(РқР°|РҗР»Рө|РўР°Рә?)[\h\v]+)[Рҗ-РҜРҶРҮР„ТҗA-Z][^\h\v]</afterbreak>
</rule>
<!-- Years: СҖСҖ. -->
<rule break="no">
<beforebreak>(?U)\b([0-9]0|[0-9]{3}0)(-[РјС…])?СҖСҖ\.[\h\v]*</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- РјР»РҪ./РјР»СҖРҙ./РіСҖРҪ. вҖ” frequent mistake -->
<rule break="no">
<beforebreak>(?U)\b(СӮРёСҒ|РјР»РҪ|РјР»СҖРҙ|РіСҖРҪ)\.[\h\v]*</beforebreak>
<afterbreak>[\h\v]*(\d|[РҡРң]Р’СӮ)</afterbreak>
</rule>
<!-- СғСҒСӮР°Р»РөРҪС– СҒРәРҫСҖРҫСҮРөРҪРҪСҸ, СүРҫ РҪРө Р·РұС–РіР°СҺСӮСҢСҒСҸ Р· РҪРөСҒРәРҫСҖРҫСҮРөРҪРёРјРё СҒР»РҫРІР°РјРё -->
<rule break="no">
<beforebreak>(?U)\b(СғРәСҖ|СҖРҫСҒ|Р°РҪРіР»?|Р°РјРөСҖ|С–СӮР°Р»|С–СҒРҝ|РҪС–Рј|С„СҖ(Р°РҪСҶ)?|Р»Р°СӮ|РіСҖРөСҶ(СҢРә)?)\.[\h\v]*</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>(?U)\b(Р°РұР·|Р°СҖРә|Р°СғРҙ|РұР»|РұСғРҙ|РұСғР»СҢРІ|РІСғР»|РҙРөСҖР¶|РҙРҫРҙ|Р·Р°РІ|Р·Рұ|Р·РІ|Р·РҫРІРҪ|РөРәРҫРҪ|С–Р»|Рә|РәРІ|РәР°РҪРҙ|РәРҪ|РҪР°РҝСҖ|РҪРҝСҖ|РҪР°СҶ|РҫРұР»|РҫРҝ|РҝР»|РҝРҫР»|РҝРҫСҮ|РҝРҝ|РҝРҫСҖ|РҝСҖРҫСҒРҝ|СҖРҫР·Рҙ|СҒСӮРҫСҖ|СӮР°РұР»|[РўСӮ]]РөР»|СҮ|СҮР°СҒСӮ)\.[\h\v]*</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>(?U)\b(РәС–РҪ)\.[\h\v]*</beforebreak>
<afterbreak>(?U)[Р°-СҸС–С—С”Т‘0-9IXV]|[РҶРҘ]+\b</afterbreak>
</rule>
<rule break="no">
<beforebreak>(?U)\b[СҒРЎ]СӮ\.[\h\v]</beforebreak>
<afterbreak>[\h]*(?!([РҗР’РЈРһРҶР„]|РқР°|РҗР»Рө|РўР°Рә?)[\h\v])</afterbreak>
</rule>
<!-- РҪР°СҖ. 1945 СҖ. | (1966 СҖ. РҪР°СҖ.) | 1975 вҖ” РҪР°СҖ. РһСҒРёРҝСҮСғРә -->
<rule break="no">
<beforebreak>([0-9]|[-вҖ“вҖ”])[\h\v]+РҪР°СҖ\.[\h\v]*</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>(?U)\bРҪР°СҖ\.[\h\v]*</beforebreak>
<afterbreak>([0-9]|РұР»\.|Р°СҖСӮ\.)</afterbreak>
</rule>
<rule break="no">
<beforebreak>(?U)\bРҙРҫР»\.[\h\v]*</beforebreak>
<afterbreak>РЎРЁРҗ</afterbreak>
</rule>
<!-- Рҝ. 10 РІС–Рҙ 11.10.1933, Рҙ. Р’Р°СҒРёР»СҢ -->
<rule break="no">
<beforebreak>(?U)(?&lt;!СӮ\.[\h\v]?)\b[РҝРҙ]\.[\h\v]*</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- СғСҒСӮР°Р»РөРҪС– СҒРәРҫСҖРҫСҮРөРҪРҪСҸ, СүРҫ Р·РұС–РіР°СҺСӮСҢСҒСҸ Р· РҪРөСҒРәРҫСҖРҫСҮРөРҪРёРјРё СҒР»РҫРІР°РјРё -->
<rule break="no">
<beforebreak>(?U)\b(РҙРёРІ)\.[\h\v]</beforebreak>
<afterbreak>[\h\v]*[^Рҗ-РҜРҶРҮР„Тҗ]</afterbreak>
</rule>
<!-- Р’РөСҖС…РҫРІРҪРёР№ РҫСҖРіР°РҪ, РҙРёРІ. РҗС„СҖРёРәР°РҪСҒСҢРәРёР№ РҪР°СҶС–РҫРҪР°Р»СҢРҪРёР№ РәРҫРҪРіСҖРөСҒ -->
<rule break="no">
<beforebreak>[,вҖҗ-вҖ•-][\h\v]*(РҙРёРІ)\.[\h\v]*</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- СҒРәРҫСҖРҫСҮРөРҪРҪСҸ РІ РҙСғР¶РәР°С…:
    РЈРәСҖР°С—РҪРё (РҙРёРІ. Р—РёРјРҫРІС– РҝРҫС…РҫРҙРё)
-->
<rule break="no">
<beforebreak>(?U)(\([^)]*|\[[^\]]*|,[\h\v]*)\b(РҙРёРІ)\.[\h\v]*</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- abbreviation with proper noun: РҝСҖРҫС„. Р“СҖРёСҶСҢРәРҫ, Рҫ. РӣС–СҒРҫРІРө -->
<rule break="no">
<beforebreak>(?U)\b(Р°Рҝ|[РҗР°]РәР°Рҙ|[РҹРҝ]СҖРҫС„|[Р”Рҙ]РҫСҶ|[РҗР°]СҒРёСҒСӮ|[Р СҖ]РөР¶|[РҗР°]СҖС…|[РЎСҒ]РІРІ?|Рҫ|РҫР·|С–Рј|С–РҪР¶|РҙРёСҖ|СӮРҫРІ|СғРҝРҫСҖСҸРҙ|СӮСӮ|СҮР»\.-РәРҫСҖ|[РҹРҝ]СҖРөРҝ|[СҒРЎ]РІСӮ)\.[\h\v]*</beforebreak>
<afterbreak>[\h\v]*[Рҗ-РҜРҶРҮР„ТҗA-Z]</afterbreak>
</rule>
<rule break="no">
<beforebreak>(?U)(?&lt;![С–Рё]\s+)\bРҙСҖ\.[\h\v]*</beforebreak>
<afterbreak>[\h\v]*[Рҗ-РҜРҶРҮР„Тҗ]</afterbreak>
</rule>
<rule break="no">
<beforebreak>(?U)\bРңР°РҪ\.[\h\v]*</beforebreak>
<afterbreak>[\h\v]*([РЎСҒ]С–СӮС–|[Р®СҺ]РҪ)</afterbreak>
</rule>
<!-- СҒРјРөСҖСӮСҢ РіСҖ. Р‘РҫР»СӮР°СҖРҫРІРёСҮР°, but not "9 РіСҖ." -->
<rule break="no">
<beforebreak>[^0-9][\h\v]+[Р“Рі]СҖ\.[\h\v]*</beforebreak>
<afterbreak>[\h\v]*[Рҗ-РҜРҶРҮР„ТҗA-Z]</afterbreak>
</rule>
<!-- TODO: Р°СҖСӮ. - Р°СҖСӮРёСҒСӮ -->
<rule break="no">
<beforebreak>(?U)\b([РҗР°]СҖСӮ|[РңРј]Р°Р»|[Р СҖ]РёСҒ|[РЎСҒ]РҝСҖ)\.[\h\v]*</beforebreak>
<afterbreak>[\h\v]*(в„–[\h\v]*)?[0-9]</afterbreak>
</rule>
<!-- РҘРҶРҶ СҖ., 3-6 Р°СҖСӮ., 2-3 СӮСӮ. -->
<rule break="no">
<beforebreak>[0-9][\h\v]+(Р°СҖСӮ|СӮСӮ)\.[\h\v]*</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- Р°Р»Рө СҖРҫР·РұРёРІР°С”РјРҫ В«РІСҒСҢРҫРіРҫ 20 Рј. РҹРҫСҮР°Р»РҫСҒСҸВ» -->
<rule break="no">
<beforebreak>(?U)(?&lt;!\d[\h\v]*)\bРј\.[\h\v]*</beforebreak>
<afterbreak>[Рҗ-РҜРҶРҮР„Тҗ][Р°-СҸС–С—С”Т‘']</afterbreak>
</rule>
<!-- СҒРөР»Рҫ/СҒСӮРҫСҖС–РҪРәР°/РјС–СҒСӮРҫ, Р°Р»Рө СүРҫРұ РҪРө Р·РұС–РіР°Р»РҫСҒСҸ Р· СҒРөРәСғРҪРҙР°РјРё/РјРөСӮСҖР°РјРё -->
<rule break="no">
<beforebreak>([\h\v][В«(][СҒРј]|[^0-9/. ][\h\v]+[СҒРј])\.[\h\v]+</beforebreak>
<afterbreak>[Рҗ-РҜРҶРҮР„Тҗ][Р°-СҸС–С—С”Т‘']</afterbreak>
</rule>
<!-- (СҖРөР¶. Р•РјРјР°РҪСҺРөР»СҢ -->
<rule break="no">
<beforebreak>[(В«"вҖһвҖңвҖқ\[вҖ№][Р°-СҸС–С—С”Т‘]+\.[\h\v]+</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- РҫСҖРөРҪРҙР° РәР°РұС–РҪРөСӮС–РІ РәРҫСҲСӮСғРІР°Р»Р° (!) 22,36 РјР»РҪ РіСҖРҪ. -->
<rule break="no">
<beforebreak>["В«вҖһвҖңвҖқ\[][.!?вҖҰ]{1,3}["В»вҖқвҖң\]][\h\v]+</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- СҒСӮР°СӮСғСҒ РҝСҖР°РІРҫРІРёС… РҙРөСҖР¶Р°РІ. вҖ” РҗРІСӮ.). -->
<rule break="no">
<beforebreak></beforebreak>
<afterbreak>[\h\v]*[вҖҗ-вҖ•-][\h\v]*([Р СҖ]РөРҙ|[РҗР°]РІСӮ)\.[\h\v]*[\)\]]</afterbreak>
</rule>
<rule break="no">
<beforebreak>(?U)\b([Р СҖ]РөРҙ)\.[\h\v]*</beforebreak>
<afterbreak>[Рҗ-РҜРҶРҮР„Тҗ]</afterbreak>
</rule>
<!-- РҰРөРҪР·РҫСҖ.РқР•Рў -->
<rule break="no">
<beforebreak>[Р°-СҸС–С—С”Т‘]\.</beforebreak>
<afterbreak>РқР•Рў|РҶРҪС„Рҫ|Info|City|Life|UA|Р Сғ</afterbreak>
</rule>
<!-- Р°Р»Рө Р»РёСҲР°С”РјРҫ С–РҪС–СҶС–Р°Р»Рё: РЎ.\u202F РЁРөР»СғС…РёРҪ -->
<rule break="yes">
<beforebreak>(?&lt;!\h[Рҗ-РҜРҶРҮР„Тҗ])[.!?вҖҰ]{1,3}\u202F[\h\v]+</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="yes">
<beforebreak>[.!?вҖҰ]['В»"вҖһвҖңвҖқ\]вҖә\u0002]*[\h\v]+</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- Р’СҒСҢРҫРіРҫ 33 СӮРёСҒ.Рҗ РјРҫР¶РөР№ Р№ РұС–Р»СҢСҲРө -->
<rule break="yes">
<beforebreak>[.!?вҖҰ]['В»"вҖһвҖңвҖқ)\]вҖә]*</beforebreak>
<afterbreak>\p{Lu}[^\p{Lu}]</afterbreak>
</rule>
<!-- вҖңРЎР»РҫРҪвҖқ (2008 СҖ.) РЈ РјРёРҪСғР»РҫРјСғ С…Р°СҖРәС–РІвҖҷСҸРҪРәР° -->
<rule break="yes">
<beforebreak>[.!?вҖҰ]['В»"вҖһвҖңвҖқ)\]вҖә]?[\h\v]+</beforebreak>
<afterbreak>([вҖҗ-вҖ•-][\h\v]*)?\p{Lu}[^\p{Lu}]</afterbreak>
</rule>
</languagerule>

<languagerule languagerulename="Belarusian">
<rule break="no">
<beforebreak>\b\d+\.\s</beforebreak>
<afterbreak>\p{Ll}|\p{Lu}{2,}</afterbreak>
</rule>
<!-- capital char abbreviations Рҗ. Р‘. Р’. -->
<rule break="no">
<beforebreak>\b[Рҗ-РҜРҒ]\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>\bРҺ\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
