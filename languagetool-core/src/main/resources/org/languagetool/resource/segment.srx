</rule>
</languagerule>
<languagerule languagerulename="Serbian">
<!-- Don't split at e.g. "d. h." -->
<rule break="no">
<beforebreak>[^-\p{L}'â]\p{L}[\.!?âŠ]['|"|â|Â«|\)|\]|\}]?\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<!--ĐĐ” ŃĐ°Đ·ĐŽĐČĐ°ŃĐ°ŃĐž ĐșĐŸĐŽ ĐœĐ° ĐżŃ. "U.S.A." -->
<rule break="no">
<beforebreak>\b\p{L}\.</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- Don't split after a white-space followed by a single letter followed
             by a dot followed by another whitespace. e.g. " p. " -->
<rule break="no">
<beforebreak>\s\p{L}\.\s</beforebreak>
<afterbreak>\p{L}\.</afterbreak>
</rule>
<!--ĐĐ” ŃĐ°Đ·ĐŽĐČĐ°ŃĐ°ŃĐž ĐșĐŸĐŽ "Đ±Đ»Đ° Đ±Đ»Đ°... ŃŃŃŃ ŃŃŃŃ".-->
<rule break="no">
<beforebreak>[\[\(]?\.\.\.[\]\)]?\s</beforebreak>
<afterbreak>\p{Ll}</afterbreak>
</rule>
<!--ĐĐ” ŃĐ°Đ·ĐŽĐČĐ°ŃĐ°ŃĐž [.?!] ĐșĐ°ĐŽĐ° ŃĐ” ĐœĐ°Đ»Đ°Đ·Đ” ŃĐœŃŃĐ°Ń Đ·ĐœĐ°ĐșĐŸĐČĐ° ĐœĐ°ĐČĐŸĐŽĐ°,
ŃĐ”ĐŽĐœĐŸŃŃŃŃĐșĐžŃ ĐžĐ»Đž ĐŽĐČĐŸŃŃŃŃĐșĐžŃ. -->
<rule break="no">
<beforebreak>['"â][\.!?âŠ]['"â]\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- Don't break after quote unless there's a capital letter
             e.g.: "That's right!" he said.

ĐĐ” ŃĐ°Đ·ĐŽĐČĐ°ŃĐ°ŃĐž ĐżĐŸŃĐ»Đ” ĐœĐ°ĐČĐŸĐŽĐœĐžĐșĐ° ĐŸŃĐžĐŒ Đ°ĐșĐŸ ĐœĐžŃŃ ĐżŃĐ°ŃĐ”ĐœĐž
ĐČĐ”Đ»ĐžĐșĐžĐŒ ŃĐ»ĐŸĐČĐŸĐŒ. ĐĐ° ĐżŃĐžĐŒĐ”Ń:
    "ĐąĐ°ĐșĐŸ ŃĐ”!", ŃĐ”ŃĐ” ĐŸĐœ.-->
<rule break="no">
<beforebreak>["'â],\s</beforebreak>
<afterbreak>\p{Ll}</afterbreak>
</rule>
<!-- e.g. "Das ist . so." - assume one sentence. -->
<rule break="no">
<beforebreak>\s([\.!?]{1,3}|âŠ)['|"|â|Â«|\)|\]|\}]?\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<!--ĐŃĐŸŃĐ”ĐČĐž, ĐŽĐ°ŃŃĐŒĐž ĐœĐ° ĐżŃ. "ĐĐ°ĐœĐ° 3.10."-->
<rule break="no">
<beforebreak>\b\d+\.\s</beforebreak>
<afterbreak>\p{Ll}|\p{Lu}{2,}</afterbreak>
</rule>
<!--ĐĐ° ĐżŃ.: "ĐĐČĐŸ ĐŸĐČĐŽĐ” ŃĐ” ŃĐ°ĐșĐŸŃĐ”(!) ŃĐ”ĐŽĐœĐ° ŃĐ”ŃĐ”ĐœĐžŃĐ°".-->
<rule break="no">
<beforebreak>[\(\[][!?]{1,3}[\]\)]\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<!--ĐĐ° ĐżŃ.: "ĐĐČĐŸ ĐŸĐČĐŽĐ” ŃĐ” (ŃĐ°ĐșĐŸŃĐ”!) ŃĐ”ĐŽĐœĐ° ŃĐ”ŃĐ”ĐœĐžŃĐ°."-->
<rule break="no">
<beforebreak>[!?]{1,3}[\)\]]\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<!--ĐĐ” ŃĐ°Đ·ĐŽĐČĐ°ŃĐ°Ń Ń ŃĐ»ŃŃĐ°ŃŃ ĐșĐ°ĐŸ ĐœĐ° ĐżŃ.: "ĐĐ”ŃĐ°Ń I ĐŽĐŸŃĐ°ĐŸ ŃĐ” ..."-->
<rule break="no">
<beforebreak>[\sÂ ][IVX]+\s</beforebreak>
<afterbreak>[^\p{Lu}]+</afterbreak>
</rule>
<!--ĐĐ” ŃĐ°Đ·ĐŽĐČĐ°ŃĐ°Ń Ń ŃĐ»ŃŃĐ°ŃŃ ĐșĐ°ĐŸ "ĐŸĐŽ 13. ĐŽĐŸ 14. ĐČĐ”ĐșĐ°"-->
<rule break="no">
<beforebreak>\d+\.\s</beforebreak>
<afterbreak>(Đž|ĐžĐ»Đž|ĐŽĐŸ)\s</afterbreak>
</rule>
<!--ĐĐ” ŃĐ°Đ·ĐŽĐČĐ°ŃĐ°Ń Ń ŃĐ»ŃŃĐ°ŃŃ ĐŽĐ°ŃŃĐŒĐ° ĐżĐžŃĐ°ĐœĐŸĐł ĐŒĐ”ŃĐŸĐČĐžŃĐŸ - ĐŽĐ°Đœ Đ°ŃĐ°ĐżŃĐșĐžĐŒ ŃĐžŃŃĐ°ĐŒĐ°,
Đ° ĐœĐ°Đ·ĐžĐČ ĐŒĐ”ŃĐ”ŃĐ° ŃĐ»ĐŸĐČĐžĐŒĐ°: "ĐĐœĐ” 28. ŃŃĐœĐ°"-->
<rule break="no">
<beforebreak>\d+\.\s</beforebreak>
<afterbreak>ŃĐ°ĐœŃĐ°Ń|ŃĐ°ĐœŃĐ°ŃĐ°|ŃĐ”Đ±ŃŃĐ°Ń|ŃĐ”Đ±ŃŃĐ°ŃĐ°|ĐŒĐ°ŃŃ|ĐŒĐ°ŃŃĐ°|Đ°ĐżŃĐžĐ»|Đ°ĐżŃĐžĐ»Đ°|ĐŒĐ°Ń|ĐŒĐ°ŃĐ°|ŃŃĐœ|ŃŃĐœĐ°|ŃŃĐ»|ŃŃĐ»Đ°|Đ°ĐČĐłŃŃŃ|Đ°ĐČĐłŃŃŃĐ°|ŃĐ”ĐżŃĐ”ĐŒĐ±Đ°Ń|ŃĐ”ĐżŃĐ”ĐŒĐ±ŃĐ°|ĐŸĐșŃĐŸĐ±Đ°Ń|ĐŸĐșŃĐŸĐ±ŃĐ°|ĐœĐŸĐČĐ”ĐŒĐ±Đ°Ń|ĐœĐŸĐČĐ”ĐŒĐ±ŃĐ°|ĐŽĐ”ŃĐ”ĐŒĐ±Đ°Ń|ĐŽĐ”ŃĐ”ĐŒĐ±ŃĐ°</afterbreak>
</rule>
<!--ĐĐ” ŃĐ°Đ·ĐŽĐČĐ°ŃĐ°Ń Ń ŃĐ»ŃŃĐ°ŃĐ”ĐČĐžĐŒĐ° ĐșĐ°ĐŸ ĐœĐ° ĐżŃ.: "Ń 1. ŃŃĐ”ĐżĐ”ĐœŃ ŃŃĐŸĐŽŃŃĐČĐ°".-->
<rule break="no">
<beforebreak>\d+\.\s</beforebreak>
<afterbreak>ŃŃĐ”ĐżĐ”Đœ(Ń)</afterbreak>
</rule>
<!-- German abbreviations -->
<rule break="no">
<beforebreak>\b(versch|d|Ăbers|usw|Ab[hkts]|ahd|Akk|aktual|allg|alltagsspr|altdt|alttest|amerikan|Anh|Ank|Anm|Art|Az|Bat|bayr|Bd|Bde|bearb|Bed|Bem|bes|bez|Bez|Bhf|bspw|btto|bw|bzw|pot)\.\s</beforebreak>
