<languagerule languagerulename="Ukrainian">
<!-- when sentence starts with ellipsis: ...–Ь–∞–Ј—Ц–є —Ц –Ѓ—Е–Є–Љ —В–µ–ґ. -->
<rule break="no">
<beforebreak>(^|[\h])(\.\.\.|вА¶)</beforebreak>
