<languagerule languagerulename="Danish">
<!-- Split e.g.: He won't. Really. -->
<rule break="yes">
<beforebreak>'\p{L}[\.!?âŠ]\s</beforebreak>
<afterbreak>\p{Lu}</afterbreak>
</rule>
