<!--support simple lists in markdown style-->
<rule break="yes">
<beforebreak>\r?\n[\u00A0\s]*[-*]+[\u00A0\s]</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- Split at e.g. "1a. Und ..." -->
<rule break="yes">
<beforebreak>\d+[a-z]\.[\u00A0\s]{1,2}</beforebreak>
<afterbreak>\p{Lu}</afterbreak>
</rule>
<!-- Don't split at e.g. "d. h." -->
<rule break="no">
<beforebreak>[^-\p{L}'ā/Ā°]\p{L}[\.!?ā¦]['|"|ā|Ā«|\)|\]|\}]?[\u00A0\s]</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>([Dd](as|er|ie|iese[rsmn]?|en|em)|[kmsd]?ein(e[rsnm]?)?|am|fĆ¼rs|ins|zum|im|am|zur) \d+\.[\u00A0\s]+</beforebreak>
<afterbreak>[A-ZĆĆĆ].*</afterbreak>
</rule>
<rule break="no">
<beforebreak>Ust.</beforebreak>
<afterbreak>Id</afterbreak>
</rule>
