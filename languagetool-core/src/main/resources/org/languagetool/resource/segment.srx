<afterbreak>\h*(([\(¬Ђ]|[\[вАР-вАХ-][\h\v]*)?\p{Ll})</afterbreak>
</rule>
<rule break="no">
<beforebreak>([\[\(]*[\]\)]*|\.\.\.|вА¶)[\h\v]+</beforebreak>
<afterbreak>[\h\v]*\p{Ll}</afterbreak>
</rule>
<!-- lowercase letter abbreviations together: –љ.–µ., –Ї–≤.–Љ. -->
<rule break="no">
<beforebreak>(?U)\b\p{L}{1,2}\.</beforebreak>
<afterbreak>\p{L}{1,2}\.</afterbreak>
</rule>
<!-- latin capital char abbreviations A. B. C. -->
<rule break="no">
<beforebreak>(?U)\b[\u00A0\u202F]?[A-Z]\.[\h\v]?</beforebreak>
<afterbreak>[A-Z][a-zA-Z'вАЩ.-]|[–Р-–ѓ–Ж–З–Д“Р]\.</afterbreak>
</rule>
<!-- capital char abbreviations –Р. –С. –Т. -->
<rule break="no">
<beforebreak>(?U)(^[\h\v]*|\([\h\v]*|[¬ЂвАЮ"]|(\b[–Р-–ѓ–Ж–З–Д“РACEIHOPX]\.-))[–Р-–ѓ–Ж–З–Д“РA-Z]\.[\h\v]*</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- –Ж–≤–∞–љ –І. (1914 —А. –љ.) -->
<rule break="no">
<beforebreak>[\h\v][–Р-–ѓ–Ж–З–Д“Р]\.[\h\v]*</beforebreak>
<afterbreak>[–Р-–ѓ–Ж–З–Д“Р]\.|[0-9]|[\h\v]*,|[\h\v]*[:¬Ђ]|\([0-9]{4}</afterbreak>
</rule>
<!-- –Ж. –Ъ–Њ–≤–∞–ї—М -->
<rule break="no">
<beforebreak>[\h\v.]([–Р-–ѓ–Ж–З–Д“РACEIHOPX]\.-)?(?&lt;!¬∞)[–Р-–ѓ–Ж–З–Д“РABCEIHOPX](?&lt;!(–Ъ—Г–∞–љ[\h]+–Ѓ|(–Я–µ—В—А|–Ю–ї–µ–Ї—Б–∞–љ–і—А)([–∞–Њ—Г]|–Њ–≤—Ц|–Њ–Љ)?[\h]+[I–Ж]+))\.[\h\v]*</beforebreak>
<afterbreak>[–Р-–ѓ–Ж–З–Д“Р][–∞-—П—Ц—Ч—Ф“С–Р-–ѓ–Ж–З–Д“Р'вАЩ Љ]{3}</afterbreak>
</rule>
<!-- –Ж–≤. –§—А–∞–љ–Ї–Њ (–∞–ї–µ –Ж–≤ –С—Г—В—Ц–ї—М—Ф) -->
<rule break="no">
