<beforebreak>[¬Ђ'"вАЮ][\.!?ЎЯвА¶]['"вАЭ¬ї]\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>\b\p{L}\.\s</beforebreak>
<afterbreak>\p{L}\.\s</afterbreak>
</rule>
<rule break="no">
<beforebreak>\b\p{L}\.</beforebreak>
<afterbreak>\p{L}\.</afterbreak>
</rule>
<rule break="yes">
<beforebreak>[^,ЎМ][\s]\p{L}{2}\.\s</beforebreak>
<afterbreak>\p{N}+\)\s</afterbreak>
</rule>
<rule break="no">
<beforebreak>[\.\s]\p{L}{1,2}\.\s</beforebreak>
<afterbreak>[\p{N}\p{Ll}]</afterbreak>
</rule>
<rule break="no">
<beforebreak>[\[\(]*\.\.\.[\]\)]* </beforebreak>
<afterbreak>[^\p{Lu}]</afterbreak>
</rule>
<rule break="no">
<beforebreak>\b\p{Lu}\.\s\p{Lu}\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>\b\p{Lu}\.\p{Lu}\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>[^\.]\s[ЎґЎµЎЂўВўБЎЇЎєўЗЎЃЎ≠ЎђЏЖЎіЎ≥џМЎ®ўДЎІЎ™ўЖўЕЏ©Џѓ\ЎЄЎЈЎ≤Ў±Ў∞ЎѓўЊўИўСўОўРўПўЛўНўМўТA-Z]\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>\(\p{Ll}+\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="yes">
<beforebreak>[\.!?ЎЯвА¶][¬Ђ¬ї\u00BB\u2019\u201D\u203A"'\p{Pe}\u0002¬є¬≤¬≥]*\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="yes">
<beforebreak>[\.!?ЎЯвА¶][¬Ђ¬ї'"\u00BB\u2019\u201D\u203A\p{Pe}\u0002]*</beforebreak>
<afterbreak>\p{Lu}[^\p{Lu}]</afterbreak>
</rule>
<rule break="yes">
<beforebreak>\s\p{L}[\.!?ЎЯвА¶]\s</beforebreak>
<afterbreak>\p{Lu}\p{Ll}</afterbreak>
</rule>
</languagerule>
<languagerule languagerulename="Serbian">
<!-- Don't split at e.g. "d. h." -->
<rule break="no">
<beforebreak>[^-\p{L}'вАЩ]\p{L}[\.!?вА¶]['|"|вАЬ|¬Ђ|\)|\]|\}]?\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<!--–Э–µ —А–∞–Ј–і–≤–∞—Ш–∞—В–Є –Ї–Њ–і –љ–∞ –њ—А. "U.S.A." -->
<rule break="no">
<beforebreak>\b\p{L}\.</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- Don't split after a white-space followed by a single letter followed
             by a dot followed by another whitespace. e.g. " p. " -->
<rule break="no">
<beforebreak>\s\p{L}\.\s</beforebreak>
<afterbreak>\p{L}\.</afterbreak>
</rule>
<!--–Э–µ —А–∞–Ј–і–≤–∞—Ш–∞—В–Є –Ї–Њ–і "–±–ї–∞ –±–ї–∞... —В—А—Г—Ы —В—А—Г—Ы".-->
<rule break="no">
<beforebreak>[\[\(]?\.\.\.[\]\)]?\s</beforebreak>
<afterbreak>\p{Ll}</afterbreak>
</rule>
<!--–Э–µ —А–∞–Ј–і–≤–∞—Ш–∞—В–Є [.?!] –Ї–∞–і–∞ —Б–µ –љ–∞–ї–∞–Ј–µ —Г–љ—Г—В–∞—А –Ј–љ–∞–Ї–Њ–≤–∞ –љ–∞–≤–Њ–і–∞,
—Ш–µ–і–љ–Њ—Б—В—А—Г–Ї–Є—Е –Є–ї–Є –і–≤–Њ—Б—В—А—Г–Ї–Є—Е. -->
<rule break="no">
<beforebreak>['"вАЮ][\.!?вА¶]['"вАЬ]\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- Don't break after quote unless there's a capital letter
             e.g.: "That's right!" he said.

–Э–µ —А–∞–Ј–і–≤–∞—Ш–∞—В–Є –њ–Њ—Б–ї–µ –љ–∞–≤–Њ–і–љ–Є–Ї–∞ –Њ—Б–Є–Љ –∞–Ї–Њ –љ–Є—Б—Г –њ—А–∞—Ы–µ–љ–Є
–≤–µ–ї–Є–Ї–Є–Љ —Б–ї–Њ–≤–Њ–Љ. –Э–∞ –њ—А–Є–Љ–µ—А:
    "–Ґ–∞–Ї–Њ —Ш–µ!", —А–µ—З–µ –Њ–љ.-->
<rule break="no">
<beforebreak>["'вАЬ],\s</beforebreak>
<afterbreak>\p{Ll}</afterbreak>
</rule>
<!-- e.g. "Das ist . so." - assume one sentence. -->
<rule break="no">
<beforebreak>\s([\.!?]{1,3}|вА¶)['|"|вАЬ|¬Ђ|\)|\]|\}]?\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<!--–С—А–Њ—Ш–µ–≤–Є, –і–∞—В—Г–Љ–Є –љ–∞ –њ—А. "–Ф–∞–љ–∞ 3.10."-->
<rule break="no">
<beforebreak>\b\d+\.\s</beforebreak>
<afterbreak>\p{Ll}|\p{Lu}{2,}</afterbreak>
</rule>
<!--–Э–∞ –њ—А.: "–Ю–≤–Њ –Њ–≤–і–µ —Ш–µ —В–∞–Ї–Њ—Т–µ(!) —Ш–µ–і–љ–∞ —А–µ—З–µ–љ–Є—Ж–∞".-->
<rule break="no">
<beforebreak>[\(\[][!?]{1,3}[\]\)]\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<!--–Э–∞ –њ—А.: "–Ю–≤–Њ –Њ–≤–і–µ —Ш–µ (—В–∞–Ї–Њ—Т–µ!) —Ш–µ–і–љ–∞ —А–µ—З–µ–љ–Є—Ж–∞."-->
<rule break="no">
<beforebreak>[!?]{1,3}[\)\]]\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<!--–Э–µ —А–∞–Ј–і–≤–∞—Ш–∞—Ш —Г —Б–ї—Г—З–∞—Ш—Г –Ї–∞–Њ –љ–∞ –њ—А.: "–Я–µ—В–∞—А I –і–Њ—И–∞–Њ —Ш–µ ..."-->
<rule break="no">
<beforebreak>[\s¬†][IVX]+\s</beforebreak>
<afterbreak>[^\p{Lu}]+</afterbreak>
</rule>
<!--–Э–µ —А–∞–Ј–і–≤–∞—Ш–∞—Ш —Г —Б–ї—Г—З–∞—Ш—Г –Ї–∞–Њ "–Њ–і 13. –і–Њ 14. –≤–µ–Ї–∞"-->
<rule break="no">
<beforebreak>\d+\.\s</beforebreak>
<afterbreak>(–Є|–Є–ї–Є|–і–Њ)\s</afterbreak>
</rule>
<!--–Э–µ —А–∞–Ј–і–≤–∞—Ш–∞—Ш —Г —Б–ї—Г—З–∞—Ш—Г –і–∞—В—Г–Љ–∞ –њ–Є—Б–∞–љ–Њ–≥ –Љ–µ—И–Њ–≤–Є—В–Њ - –і–∞–љ –∞—А–∞–њ—Б–Ї–Є–Љ —Ж–Є—Д—А–∞–Љ–∞,
–∞ –љ–∞–Ј–Є–≤ –Љ–µ—Б–µ—Ж–∞ —Б–ї–Њ–≤–Є–Љ–∞: "–Ф–љ–µ 28. —Ш—Г–љ–∞"-->
<rule break="no">
<beforebreak>\d+\.\s</beforebreak>
<afterbreak>—Ш–∞–љ—Г–∞—А|—Ш–∞–љ—Г–∞—А–∞|—Д–µ–±—А—Г–∞—А|—Д–µ–±—А—Г–∞—А–∞|–Љ–∞—А—В|–Љ–∞—А—В–∞|–∞–њ—А–Є–ї|–∞–њ—А–Є–ї–∞|–Љ–∞—Ш|–Љ–∞—Ш–∞|—Ш—Г–љ|—Ш—Г–љ–∞|—Ш—Г–ї|—Ш—Г–ї–∞|–∞–≤–≥—Г—Б—В|–∞–≤–≥—Г—Б—В–∞|—Б–µ–њ—В–µ–Љ–±–∞—А|—Б–µ–њ—В–µ–Љ–±—А–∞|–Њ–Ї—В–Њ–±–∞—А|–Њ–Ї—В–Њ–±—А–∞|–љ–Њ–≤–µ–Љ–±–∞—А|–љ–Њ–≤–µ–Љ–±—А–∞|–і–µ—Ж–µ–Љ–±–∞—А|–і–µ—Ж–µ–Љ–±—А–∞</afterbreak>
</rule>
<!--–Э–µ —А–∞–Ј–і–≤–∞—Ш–∞—Ш —Г —Б–ї—Г—З–∞—Ш–µ–≤–Є–Љ–∞ –Ї–∞–Њ –љ–∞ –њ—А.: "—Г 1. —Б—В–µ–њ–µ–љ—Г —Б—А–Њ–і—Б—В–≤–∞".-->
<rule break="no">
<beforebreak>\d+\.\s</beforebreak>
<afterbreak>—Б—В–µ–њ–µ–љ(—Г)</afterbreak>
</rule>
<!-- German abbreviations -->
<rule break="no">
<beforebreak>\b(versch|d|√Ьbers|usw|Ab[hkts]|ahd|Akk|aktual|allg|alltagsspr|altdt|alttest|amerikan|Anh|Ank|Anm|Art|Az|Bat|bayr|Bd|Bde|bearb|Bed|Bem|bes|bez|Bez|Bhf|bspw|btto|bw|bzw|pot)\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<!--–°—А–њ—Б–Ї–µ —Б–Ї—А–∞—Ы–µ–љ–Є—Ж–µ-->
<rule break="no">
<beforebreak>\b(–Њ–і–љ|—В—Ш)\.\s+</beforebreak>
<afterbreak></afterbreak>
</rule>
<!--–†–∞–Ј–і–≤–Њ—Ш –њ–Њ—Б–ї–µ –Њ–≤–Є—Е –Ј–љ–∞–Ї–Њ–≤–∞, –∞–Ї–Њ —Б—Г –њ—А–∞—Ы–µ–љ–Є —Ш–µ–і–љ–Є–Љ –Є–ї–Є –≤–µ—Ы–Є–Љ –±—А–Њ—Ш–µ–Љ —А–∞–Ј–Љ–∞–Ї–∞.-->
<rule break="yes">
<beforebreak>[\.!?вА¶][\u0002|'|"|вАЬ|\)|\]|\}¬є¬≤¬≥]?\s+</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="yes">
<beforebreak>[\.!?вА¶]['"вАЬ\p{Pe}\u00BB\u201D]?</beforebreak>
<afterbreak>\p{Lu}[^\p{Lu}]</afterbreak>
</rule>
<rule break="yes">
<beforebreak>\s\p{L}[\.!?вА¶]\s</beforebreak>
<afterbreak>\p{Lu}\p{Ll}</afterbreak>
</rule>
</languagerule>
<languagerule languagerulename="Irish">
<rule break="no">
<beforebreak>\bPh\.</beforebreak>
<afterbreak>D\.</afterbreak>
</rule>
<!-- Don't split at e.g. "U.S.A." -->
<rule break="no">
<beforebreak>\b\p{L}\.</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- Don't split after a white-space followed by a single letter followed
         by a dot followed by another whitespace. e.g. " p. " -->
<rule break="no">
<beforebreak>\s\p{L}\.\s</beforebreak>
<afterbreak>\p{L}\.</afterbreak>
</rule>
<!-- Don't split [.?!] when they're quoted -->
<rule break="no">
<beforebreak>['"][\.!?\u0085]['"]\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- Don't break after quote unless there's a capital letter
         e.g.: "That's right!" he said. -->
<rule break="no">
<beforebreak>["']\s</beforebreak>
<afterbreak>\p{Ll}</afterbreak>
</rule>
<rule break="no">
<beforebreak>(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Sept|Oct|Nov|Dec)\.\s</beforebreak>
<afterbreak>\d\d(\d\d)?</afterbreak>
</rule>
<rule break="no">
<beforebreak>(Ean|Fea|M√°r|Aib|Bea|Mei|I√Їl|L√Їn|M\.?Fr|D\.?Fr|Sam|Nol)\.\s</beforebreak>
<afterbreak>\d\d(\d\d)?</afterbreak>
</rule>
<!-- English abbreviations - but these work globally for all languages -->
<rule break="no">
<beforebreak>\b(Mr|Mrs|Ms|No|pp|St|no|Sr|Jr|Bros|etc|vs|esp|[Ff]ig|Jan|Feb|Mar|Apr|Jun|Jul|Aug|Sep|Sept|Oct|Okt|Nov|Dec|PhD|al|cf|Inc|Ms|Gen|Sen|Prof|Corp|Co|Ltd)\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- Latin abbreviations - but these work globally for all languages -->
<rule break="no">
<beforebreak>\b(sp|spp)\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>([Ll]ch|[Ll]gh|[Uu]imh)\.\s</beforebreak>
<afterbreak>\d</afterbreak>
</rule>
<rule break="no">
<beforebreak>\.i\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>Msc\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>Uas\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>Teo\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>m\.sh\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- Break rules -->
<rule break="yes">
<beforebreak>[\.!?\u0085][\u0002|'|"|¬Ђ|\)|\]|\}¬є¬≤¬≥]?\s+</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="yes">
<beforebreak>[\.!?\u0085]['"\p{Pe}\u00BB\u201D]?</beforebreak>
<afterbreak>\p{Lu}[^\p{Lu}]</afterbreak>
</rule>
<rule break="yes">
<beforebreak>\s\p{L}[\.!?\u0085]\s</beforebreak>
<afterbreak>\p{Lu}\p{Ll}</afterbreak>
</rule>
</languagerule>
<languagerule languagerulename="GeneralImportant">
<!--Don't split up URLs.-->
<rule break="no">
<beforebreak>\bwww\.</beforebreak>
<afterbreak>\w</afterbreak>
</rule>
<!--Don't split up e-mail addresses.-->
<rule break="no">
<beforebreak>[\.!?]</beforebreak>
<afterbreak>\S*@</afterbreak>
</rule>
<!--Do not break on fullstop when Microsoft .Net platform is referenced.-->
<rule break="no">
<beforebreak>(^|[\s\u00A0])\.</beforebreak>
<afterbreak>(NET|Net)\b</afterbreak>
</rule>
<!--Scientific names-->
<rule break="no">
<beforebreak>A[eur]\.[\s\u00A0]*</beforebreak>
<afterbreak>(aegypti|aferensis|ramidus)</afterbreak>
</rule>
</languagerule>
<languagerule languagerulename="Arabic">
<rule break="no">
<beforebreak>\bwww\.</beforebreak>
<afterbreak>\w</afterbreak>
</rule>
<rule break="no">
<beforebreak>[\[\(]*вА¶[\]\)]* </beforebreak>
<afterbreak>\p{Ll}</afterbreak>
</rule>
<rule break="no">
<beforebreak>\p{Ps}[!?ЎЯ]+\p{Pe} </beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>[\.!?ЎЯвА¶]+\p{Pe} </beforebreak>
<afterbreak>\p{Ll}</afterbreak>
</rule>
<rule break="no">
<beforebreak>[¬Ђ¬ї"вАЭ']\s*</beforebreak>
<afterbreak>\s*\p{Ll}</afterbreak>
</rule>
<rule break="no">
<beforebreak>[¬Ђ'"вАЮ][\.!?ЎЯвА¶]['"вАЭ¬ї]\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>\b\p{L}\.\s</beforebreak>
<afterbreak>\p{L}\.\s</afterbreak>
</rule>
<rule break="no">
<beforebreak>\b\p{L}\.</beforebreak>
<afterbreak>\p{L}\.</afterbreak>
</rule>
<rule break="yes">
<beforebreak>[^,ЎМ][\s]\p{L}{2}\.\s</beforebreak>
<afterbreak>\p{N}+\)\s</afterbreak>
</rule>
<rule break="no">
<beforebreak>[\.\s]\p{L}{1,2}\.\s</beforebreak>
<afterbreak>[\p{N}\p{Ll}]</afterbreak>
</rule>
<rule break="no">
<beforebreak>[\[\(]*\.\.\.[\]\)]* </beforebreak>
<afterbreak>[^\p{Lu}]</afterbreak>
</rule>
<rule break="no">
<beforebreak>\b\p{Lu}\.\s\p{Lu}\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>\b\p{Lu}\.\p{Lu}\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>[^\.]\s[ЎІЎ®Ў™ўВЎђЎ≠ЎЃЎѓЎ∞ЎµЎґЎєЎЇўБўВўГўДўЕўЖўЗўИўЙўКЎ°Ў©Ў£ў°ўҐў£ў§ў•ў¶ўІў®ў©ў†A-Z]\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>[^\.]\s[\u064B\u064C\u064D\u064E\u064F\u0650\u0651\u0652\u0653\u0654\u0655\u0656\u0640]\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>\(\p{Ll}+\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="yes">
<beforebreak>[\.!?ЎЯвА¶][¬Ђ¬ї\u00BB\u2019\u201D\u203A"'\p{Pe}\u0002¬є¬≤¬≥]*\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="yes">
<beforebreak>[\.!?ЎЯвА¶][¬Ђ¬ї'"\u00BB\u2019\u201D\u203A\p{Pe}\u0002]*</beforebreak>
<afterbreak>\p{Lu}[^\p{Lu}]</afterbreak>
</rule>
<rule break="yes">
<beforebreak>\s\p{L}[\.!?ЎЯвА¶]\s</beforebreak>
<afterbreak>\p{Lu}\p{Ll}</afterbreak>
</rule>
</languagerule>
<languagerule languagerulename="Swedish">
<rule break="no">
<beforebreak>\b(alt|bl\.a|dvs|etc|ev|forts|inkl|fr\.o\.m|[Ff]\.d|m\.a\.o|[Oo]rig|osv|p\.g\.a|prel|[Rr]ef|resp|s\.k|st|t\.ex|[Kk]ol|[Ff]ig|[Aa]rt|[Bb]il)\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="no">
<beforebreak>\s√ґvr\.\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="yes">
<beforebreak>[\.!?вА¶][\u00BB\u2019\u201D\u203A"'\p{Pe}\u0002¬є¬≤¬≥]*\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="yes">
<beforebreak>[\.!?вА¶]['"\u00BB\u2019\u201D\u203A\p{Pe}\u0002]*</beforebreak>
<afterbreak>\p{Lu}[^\p{Lu}]</afterbreak>
</rule>
<rule break="yes">
<beforebreak>\s\p{L}[\.!?вА¶]\s</beforebreak>
<afterbreak>\p{Lu}\p{Ll}</afterbreak>
</rule>
</languagerule>
</languagerules>
<maprules>
<languagemap languagepattern=".*" languagerulename="GeneralImportant"></languagemap>
<languagemap languagepattern="[a-z]{2,3}_one" languagerulename="ByLineBreak"></languagemap>
<languagemap languagepattern="[a-z]{2,3}_two" languagerulename="ByTwoLineBreaks"></languagemap>
