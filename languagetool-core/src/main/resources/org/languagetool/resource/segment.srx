<!-- Numbers, dates e.g. "3.10. datiert" -->
<rule break="no">
<beforebreak>(?U)\b\d+\.[\u00A0\s]{1,2}</beforebreak>
<afterbreak>\p{Ll}|\p{Lu}{2,}</afterbreak>
</rule>
<!-- z.B. "Das hier ist ein(!) Satz." -->
