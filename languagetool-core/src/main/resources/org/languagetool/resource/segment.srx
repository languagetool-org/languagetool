</rule>
<rule break="yes">
<beforebreak>[\.!?ŰâŠ][Â«Â»\u00BB\u2019\u201D\u203A"'\p{Pe}\u0002ÂčÂČÂł]*\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="yes">
