<afterbreak>\p{Lu}</afterbreak>
</rule>
<!-- Split at "a.m." or "p.m." followed by a capital letter. -->
<rule break="yes">
<beforebreak>[ap]\.m\.\s</beforebreak>
<afterbreak>\p{Lu}</afterbreak>
</rule>
<!-- Don't split at e.g. "U. S. A." -->
<rule break="no">
