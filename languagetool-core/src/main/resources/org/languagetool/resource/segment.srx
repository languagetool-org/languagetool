<!-- mΟΓx. mΟ≠n. etc. -->
<rule break="no">
<beforebreak>\b([Ee]tc|m[aΟΓ]x|m[iΟ≠]n|aprox|\d+o)\.[\p{Pe}\p{Pf}\p{Pd}"βÄù'βÄô]*\s</beforebreak>
