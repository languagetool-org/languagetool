</rule>
<!-- –Э–∞—И—Ц –≤... –Ы–Њ—Б-–Р–љ–і–ґ–µ–ї–µ—Б—Ц -->
<rule break="no">
<beforebreak>(?U)\b(–≤|—Г|–љ–∞|–Ј–∞|–Ј|—Ц–Ј|–Ј—Ц|–Ј–Њ)(\.\.\.|вА¶)[\h\v]*</beforebreak>
<afterbreak>\p{Lu}</afterbreak>
</rule>
<rule break="no">
