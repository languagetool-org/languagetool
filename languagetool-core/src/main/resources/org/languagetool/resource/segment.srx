<!-- initials: A. C. Jones. -->
<rule break="no">
<beforebreak>(?U)\b[A-ZĆĆĆĆĆĆĆ]\.\s?</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- Two final stop abbreviations  -->
