<!-- Don't split after a white-space followed by a single letter followed
         by a dot followed by another whitespace. e.g. " p. " -->
<rule break="no">
<beforebreak>\s\p{L}\.\s?</beforebreak>
<afterbreak>\p{L}\.</afterbreak>
</rule>
<!-- Any word in acronyms like E.U.A. or P.S.P. or C. or c.s.p. or p. e. -->
<rule break="no">
<beforebreak>\b(\p{L}\.)+[\p{Pe}\p{Pf}\p{Pd}"вАЭ']*\s</beforebreak>
<afterbreak>\p{Ll}</afterbreak>
</rule>
<!-- Any word in acronyms like EE.UU. or BB. DD. -->
<rule break="no">
<beforebreak>\b([\p{Lu}]{2}\.)+[\p{Pe}\p{Pf}\p{Pd}"вАЭ']*\s</beforebreak>
<afterbreak>\p{Ll}</afterbreak>
</rule>
<!-- m√°x. m√≠n. etc. -->
<rule break="no">
<beforebreak>\b([Ee]tc|m[a√°]x|m[i√≠]n|aprox|\d+o)\.[\p{Pe}\p{Pf}\p{Pd}"вАЭ'вАЩ]*\s</beforebreak>
<afterbreak>\p{Ll}</afterbreak>
</rule>
<!-- Composed abbrev. e.g. et al. -->
<rule break="no">
<beforebreak>\bet al\.[\p{Pe}\p{Pf}\p{Pd}"вАЭ']*\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- Units -->
<rule break="no">
<beforebreak>\b([Ee]sc|K[gm]s?|[mc]?[gml]s]|[Hh](rs)?)\.[\p{Pe}\p{Pf}\p{Pd}"вАЭ'вАЩ]*\s</beforebreak>
<afterbreak>\p{Ll}</afterbreak>
</rule>
<!-- Split at e.g. "1a. There is..." -->
<rule break="yes">
<beforebreak>\d+[a-z]\.\s?</beforebreak>
<afterbreak>\p{Lu}</afterbreak>
</rule>
<!-- Don't split at cases like "in 13. or 14. paragraphs" -->
<rule break="no">
<beforebreak>\d+\.\s?</beforebreak>
<afterbreak>(e|ou|at√©)\s</afterbreak>
</rule>
<!-- Don't split [.?!] when they're quoted -->
<rule break="no">
<beforebreak>['"вАЬ][\.!?вА¶]['"вАЭ]\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- Not break for ellipses (...) -->
<rule break="no">
<beforebreak>[^\s](\.\.\.|вА¶)\s</beforebreak>
<afterbreak>\p{Ll}</afterbreak>
</rule>
<!-- z.B. "bla (...) blubb" -> without ending sentence -->
<rule break="no">
<beforebreak>[\(\)\[\]]\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- Don't break after quote unless there's a capital letter
         e.g.: "That's right!" he said. -->
<rule break="no">
<beforebreak>["вАЭ'вАЩ]\s</beforebreak>
<afterbreak>\p{Ll}</afterbreak>
</rule>
<!-- z.B. "This is a (!) exclamation." -->
<rule break="no">
<beforebreak>[\(\[][!?]{1,3}[\]\)]\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- z.B. "This here is an (awesome!) phrase." -->
<rule break="no">
<beforebreak>[!?]{1,3}[\)\]]\s</beforebreak>
<afterbreak></afterbreak>
</rule>
<!-- narrator comments in dialogs -->
<rule break="no">
<beforebreak>[\.!?вА¶]\s</beforebreak>
<afterbreak>[-вАУвАФ],?\s\p{Ll}.+</afterbreak>
</rule>
<!-- Break rules -->
<rule break="yes">
<beforebreak>\b(etc)\.\s?</beforebreak>
<afterbreak>\p{Lu}\p{Ll}*</afterbreak>
</rule>
<rule break="yes">
<beforebreak>[\.!?][\u0002|'|"|вАЬ|¬Ђ|\)|\]|\}¬є¬≤¬≥]?\s+</beforebreak>
<afterbreak></afterbreak>
</rule>
<rule break="yes">
<beforebreak>[\.!?вА¶]['"вАЭ¬ї\p{Pe}\u00BB\u201D]?\s*</beforebreak>
<afterbreak>\p{Lu}[^\p{Lu}]</afterbreak>
</rule>
<rule break="yes">
<beforebreak>\s\p{L}[\.!?вА¶]\s</beforebreak>
<afterbreak>\p{Lu}\p{Ll}*</afterbreak>
</rule>
<rule break="yes">
<beforebreak>[^\s]:\s</beforebreak>
<afterbreak>['"¬Ђ¬°¬њ\p{Ps}\p{Pi}]\p{Lu}\p{Ll}*</afterbreak>
</rule>
<rule break="yes">
