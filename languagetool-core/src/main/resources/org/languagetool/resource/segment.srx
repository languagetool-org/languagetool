<!-- Year: 2000 —А.:
    –≤–Є—А–Њ–±–Є–ї–∞ —Г 2018 —А. 8,1 –Љ–ї–љ –і–µ–Ї–∞–ї—Ц—В—А—Ц–≤
    –≤—Ц–і 26 –Ї–≤—Ц—В–љ—П 2017 —А. вДЦ35
    –∞ –і–Њ –ї—О—В–Њ–≥–Њ 2020 —А. вАФ –Ј–∞—В–≤–µ—А–і–Є—В–Є
-->
<rule break="no">
<beforebreak>(?U)\b([0-9]{2}|[0-9]{4})[\h\v]+—А\.[\h\v]+</beforebreak>
<afterbreak>[\h\v]*[вДЦ0-9вАР-вАХ-]</afterbreak>
</rule>
<!-- —А—Ц—З–Ї–∞ - —А. –Ф–љ—Ц–њ—А–Њ -->
