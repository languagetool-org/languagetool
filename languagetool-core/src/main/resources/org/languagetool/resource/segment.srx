<rule break="no">
<beforebreak>[\u00A0\s]\p{L}\.[\u00A0\s]{1,2}</beforebreak>
<afterbreak>\p{L}\.</afterbreak>
</rule>
<!-- Don't split at "bla bla... yada yada" -->
<rule break="no">
